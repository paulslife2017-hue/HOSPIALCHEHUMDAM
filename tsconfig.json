{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2020", "DOM"],
    "types": ["node"],
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["api/**/*", "src/pages/**/*"],
  "exclude": ["node_modules", "dist", "src/index.tsx", "src/renderer.tsx"]
}
